<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="820.0" prefWidth="1280.0" stylesheets="@../css/background.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="View.GUI.OtherPlayerStationController">
   <children>
      <VBox alignment="CENTER" layoutX="140.0" layoutY="9.0" prefHeight="748.0" prefWidth="1000.0" spacing="20.0">
         <children>
            <Label fx:id="label" alignment="CENTER" prefHeight="30.0" prefWidth="1000.0" stylesheets="@../css/labelText.css" text="Label" />
            <ScrollPane hbarPolicy="ALWAYS" prefHeight="650.0" prefWidth="1000.0" vbarPolicy="ALWAYS">
               <content>
                  <Pane fx:id="stationPane" prefHeight="2250.0" prefWidth="3000.0" style="-fx-background-color: GREY;" />
               </content>
            </ScrollPane>
            <Button fx:id="goBackButton" mnemonicParsing="false" text="Go back" />
         </children>
      </VBox>
   </children>
</AnchorPane>
